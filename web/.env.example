# SQL Server connection
DB_SERVER=.
DB_DATABASE=pharmabill

# SQL Server Authentication (leave blank if using Windows Auth)
DB_USER=
DB_PASSWORD=

# Set to 'true' for Azure SQL / cloud SQL Server, 'false' for local
DB_ENCRYPT=false

# Set to 'true' to skip SSL certificate validation (local dev)
DB_TRUST_CERT=true

# Set to 'true' to use Windows Authentication (trusted connection)
# When true, DB_USER and DB_PASSWORD are ignored
DB_TRUSTED_CONNECTION=true
